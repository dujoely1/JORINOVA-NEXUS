# ============================================================================
# JORINOVA NEXUS — backend environment template
# Copy this file to  backend/.env  and fill in the real values.
#     cp .env.example .env      (Linux/Mac)
#     Copy-Item .env.example .env   (Windows PowerShell)
# Lines starting with # are comments. Do NOT commit the real .env.
# ============================================================================

# ── App ─────────────────────────────────────────────────────────────────────
APP_NAME=JORINOVA NEXUS ALIS-X
APP_VERSION=2.0.0
# debug=true shows verbose logs. Set to false / "release" for production.
DEBUG=true
# CHANGE THIS in production — used to sign login tokens. Generate a strong one:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=change-this-to-a-long-random-secret-key
# Comma-separated hostnames allowed in production (ignored when DEBUG=true).
ALLOWED_HOSTS=localhost,127.0.0.1

# How long a login session lasts, in minutes. 10080 = 7 days (stay signed in).
ACCESS_TOKEN_EXPIRE=10080

# ── Seed account passwords (NEVER hard-coded in the source) ──────────────────
# On a FRESH database the seed creates user `admin` (and `dujoely`). Set their
# passwords here. If you leave them blank, a strong RANDOM password is generated
# and printed ONCE in the server log — read it, then change it after first login.
ADMIN_PASSWORD=
OWNER_PASSWORD=

# ── Database ────────────────────────────────────────────────────────────────
# Pilot/dev default is SQLite (a single file, zero setup):
DB_ENGINE=sqlite
DB_NAME=alis_x.db
# For PRODUCTION use PostgreSQL instead — uncomment + fill these:
# DB_ENGINE=postgresql
# DB_NAME=alis_x
# DB_USER=alisx
# DB_PASSWORD=your-db-password
# DB_HOST=localhost
# DB_PORT=5432

# ── Password-reset email (forgot password) ──────────────────────────────────
# When these are set, the 6-digit reset code is EMAILED to the user (and never
# shown in the app). If left blank, the code is written to the server log only.
#
#   GMAIL SETUP (recommended for the pilot):
#   1. Use a Gmail account (e.g. dujoely1@gmail.com).
#   2. Turn ON 2-Step Verification:  https://myaccount.google.com/security
#   3. Create an App Password:        https://myaccount.google.com/apppasswords
#        - "Select app" = Mail, "Select device" = Other → type "NEXUS"
#        - Google shows a 16-character password like: abcd efgh ijkl mnop
#   4. Put that 16-char value (REMOVE the spaces) in EMAIL_HOST_PASSWORD below.
#      It is NOT your normal Gmail password.
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=dujoely1@gmail.com
EMAIL_HOST_PASSWORD=abcdefghijklmnop

# Public URL labs open (the Cloudflare tunnel or your domain). Makes the
# "Yes, it's me" link in the reset email open the app on the user's phone.
# Example: https://nexus-pilot.trycloudflare.com   (NO trailing slash)
APP_BASE_URL=

# ── SMS to patients (results ready, critical value, OTP) ────────────────────
# Without a provider configured, SMS is QUEUED in the DB but NOT delivered.
# Choose ONE provider with SMS_PROVIDER:  at  (Africa's Talking)  |  pindo
SMS_PROVIDER=at
SMS_SENDER_ID=NEXUSLAB

#  Option A — AFRICA'S TALKING  (SMS_PROVIDER=at)
#   1. Create an account:  https://account.africastalking.com
#   2. Dashboard → Settings → API Key  → copy username + API key.
#   3. pip install africastalking
#   4. SANDBOX (free) only sends to the simulator. For REAL phones switch to a
#      LIVE app, add credit, and request a Sender ID (Rwanda approval may take
#      a few days; until then leave SMS_SENDER_ID blank to use the shared one).
AT_USERNAME=
AT_API_KEY=

#  Option B — PINDO  (SMS_PROVIDER=pindo)  — Rwandan provider, often easier
#   sender-ID approval locally.  https://www.pindo.io
#   1. Create an account, top up, get your API token (Dashboard → API).
#   2. No pip package needed (NEXUS calls the Pindo REST API directly).
PINDO_API_TOKEN=
# Optional override (defaults to the public Pindo endpoint):
# PINDO_API_URL=https://api.pindo.io/v1/sms/

# ── AI (optional — system works offline without these) ──────────────────────
# Local LLM via Ollama (if installed on the server):
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=phi3:mini
# Cloud LLM via Anthropic Claude (optional enrichment; leave blank to stay offline):
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-haiku-4-5-20251001

# JORINOVA NEXUS — production/Docker env TEMPLATE.
# Copy to `.env.production` and fill in the real values. NEVER commit the filled file.
#   cp backend/.env.production.example backend/.env.production

# ── Security ─────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-long-random-string

# ── Database (PostgreSQL — Docker service names) ─────────────────────────────
DB_ENGINE=postgresql
DB_NAME=alis_x
DB_USER=alis_x_user
DB_PASSWORD=change-this-strong-password
DB_HOST=postgres          # Docker service name (use 'localhost' outside Docker)
DB_PORT=5432

# ── AI — Local (Ollama, inside Docker) ───────────────────────────────────────
OLLAMA_URL=http://ollama:11434   # Docker service; use http://localhost:11434 on the host
OLLAMA_MODEL=phi3:mini
LOCAL_AI_TIMEOUT=20
# Hybrid routing: auto = Claude online / Ollama offline; offline = force local; cloud = prefer Claude
AI_MODE=auto
# AI_AUTOPULL_MODELS=1   # pull ALL router models on startup (heavy ~16 GB; powerful host only)

# ── AI — Cloud (Anthropic / Claude) ──────────────────────────────────────────
# Leave blank to stay fully offline. Get a key: https://console.anthropic.com
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-haiku-4-5-20251001
CLOUD_AI_TIMEOUT=30

# ── App ──────────────────────────────────────────────────────────────────────
APP_BASE_URL=http://localhost:3000
# Login: false = pure username/password (no 2FA gate). Set true to force
# super_admins through two-factor enrolment before they can use the app.
FORCE_2FA=false

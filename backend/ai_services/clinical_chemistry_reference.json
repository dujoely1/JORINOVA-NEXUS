{
  "_meta": {
    "purpose": "Clinical chemistry (biochemistry) reference intervals + critical values for the INTERPRETATION layer. The rules engine + LLM read a measured analyte and this table to flag low/normal/high/critical and to run panel logic (renal, LFT, lipids, cardiac, bone). Adult ranges unless noted. Decision support only; verify against local assay + population.",
    "significance_levels": ["normal", "low", "high", "critical"],
    "note": "Ranges are typical adult SI-adjacent conventional units; ALWAYS confirm against the reporting laboratory's own reference intervals and units.",
    "source": "Tietz / standard laboratory reference intervals. Curated for JORINOVA NEXUS.",
    "consumed_by": ["clinical_rules.py", "cloud_llm.py", "medical_rag.py"]
  },

  "analytes": {
    "sodium":        {"name": "Sodium", "units": "mmol/L", "ref_low": 135, "ref_high": 145, "critical_low": 120, "critical_high": 160, "panel": "electrolytes"},
    "potassium":     {"name": "Potassium", "units": "mmol/L", "ref_low": 3.5, "ref_high": 5.1, "critical_low": 2.5, "critical_high": 6.5, "panel": "electrolytes", "note": "Critical high -> ECG + urgent treatment; exclude haemolysis/thrombocytosis (pseudo)."},
    "chloride":      {"name": "Chloride", "units": "mmol/L", "ref_low": 98, "ref_high": 107, "panel": "electrolytes"},
    "bicarbonate":   {"name": "Bicarbonate (CO2)", "units": "mmol/L", "ref_low": 22, "ref_high": 29, "panel": "electrolytes", "note": "Low -> metabolic acidosis (check anion gap); high -> metabolic alkalosis."},
    "anion_gap":     {"name": "Anion gap", "units": "mmol/L", "ref_low": 8, "ref_high": 16, "panel": "electrolytes", "note": "High -> MUDPILES (lactate, ketones, toxins, uraemia)."},
    "urea":          {"name": "Urea (BUN)", "units": "mmol/L", "ref_low": 2.5, "ref_high": 7.8, "panel": "renal", "note": "High urea:creatinine ratio -> pre-renal / GI bleed."},
    "creatinine":    {"name": "Creatinine", "units": "µmol/L", "ref_low": 60, "ref_high": 110, "critical_high": 500, "panel": "renal", "note": "Interpret with eGFR + baseline; rising = AKI."},
    "egfr":          {"name": "eGFR", "units": "mL/min/1.73m2", "ref_low": 90, "ref_high": 200, "critical_low": 15, "panel": "renal", "note": "<15 = kidney failure (consider RRT); stage CKD by eGFR + ACR."},
    "glucose_fasting":{"name": "Glucose (fasting)", "units": "mmol/L", "ref_low": 3.9, "ref_high": 5.5, "critical_low": 2.5, "critical_high": 25, "panel": "glucose", "note": ">=7.0 fasting (x2) = diabetes; 5.6-6.9 = impaired fasting glucose."},
    "glucose_random":{"name": "Glucose (random)", "units": "mmol/L", "ref_low": 3.9, "ref_high": 7.8, "critical_low": 2.5, "critical_high": 25, "panel": "glucose", "note": ">=11.1 with symptoms = diabetes."},
    "hba1c":         {"name": "HbA1c", "units": "mmol/mol", "ref_low": 20, "ref_high": 41, "panel": "glucose", "note": ">=48 mmol/mol (6.5%) = diabetes; 42-47 = pre-diabetes. Unreliable in haemoglobinopathy/anaemia."},
    "calcium":       {"name": "Calcium (total)", "units": "mmol/L", "ref_low": 2.2, "ref_high": 2.6, "critical_low": 1.6, "critical_high": 3.5, "panel": "bone", "note": "Correct for albumin; critical high -> hypercalcaemic crisis (malignancy/PTH)."},
    "corrected_calcium":{"name": "Corrected calcium", "units": "mmol/L", "ref_low": 2.2, "ref_high": 2.6, "panel": "bone", "note": "= measured Ca + 0.02 x (40 - albumin g/L)."},
    "phosphate":     {"name": "Phosphate", "units": "mmol/L", "ref_low": 0.8, "ref_high": 1.5, "panel": "bone"},
    "magnesium":     {"name": "Magnesium", "units": "mmol/L", "ref_low": 0.7, "ref_high": 1.0, "critical_low": 0.4, "panel": "electrolytes", "note": "Low Mg -> refractory hypokalaemia/hypocalcaemia + arrhythmia."},
    "total_protein": {"name": "Total protein", "units": "g/L", "ref_low": 60, "ref_high": 80, "panel": "lft"},
    "albumin":       {"name": "Albumin", "units": "g/L", "ref_low": 35, "ref_high": 50, "panel": "lft", "note": "Low -> chronic disease/nephrotic/malnutrition; affects corrected Ca + drug binding."},
    "bilirubin_total":{"name": "Bilirubin (total)", "units": "µmol/L", "ref_low": 3, "ref_high": 21, "panel": "lft", "note": "Split conjugated vs unconjugated; >50 visible jaundice."},
    "bilirubin_direct":{"name": "Bilirubin (conjugated/direct)", "units": "µmol/L", "ref_low": 0, "ref_high": 7, "panel": "lft", "note": "Raised -> cholestatic/hepatocellular; unconjugated -> haemolysis/Gilbert."},
    "alt":           {"name": "Alanine aminotransferase (ALT)", "units": "U/L", "ref_low": 0, "ref_high": 41, "panel": "lft", "note": "Hepatocellular marker; >1000 -> ischaemia/viral/toxin (paracetamol)."},
    "ast":           {"name": "Aspartate aminotransferase (AST)", "units": "U/L", "ref_low": 0, "ref_high": 40, "panel": "lft", "note": "AST>ALT (ratio>2) -> alcoholic liver disease."},
    "alp":           {"name": "Alkaline phosphatase (ALP)", "units": "U/L", "ref_low": 30, "ref_high": 130, "panel": "lft", "note": "Raised with GGT -> cholestasis; isolated -> bone (Paget), pregnancy, growth."},
    "ggt":           {"name": "Gamma-GT (GGT)", "units": "U/L", "ref_low": 0, "ref_high": 60, "panel": "lft", "note": "Confirms hepatic source of raised ALP; alcohol marker."},
    "amylase":       {"name": "Amylase", "units": "U/L", "ref_low": 28, "ref_high": 100, "panel": "pancreatic", "note": ">3x ULN -> acute pancreatitis (lipase more specific)."},
    "lipase":        {"name": "Lipase", "units": "U/L", "ref_low": 13, "ref_high": 60, "panel": "pancreatic", "note": ">3x ULN -> acute pancreatitis."},
    "urate":         {"name": "Urate (uric acid)", "units": "µmol/L", "ref_low": 200, "ref_high": 430, "note": "High -> gout, tumour lysis, renal failure."},
    "ldh":           {"name": "Lactate dehydrogenase (LDH)", "units": "U/L", "ref_low": 135, "ref_high": 225, "note": "Non-specific; raised in haemolysis, tumour lysis, lymphoma, infarction."},
    "crp":           {"name": "C-reactive protein (CRP)", "units": "mg/L", "ref_low": 0, "ref_high": 5, "note": "Acute-phase; >100 -> bacterial infection likely."},
    "troponin":      {"name": "Troponin (hs)", "units": "ng/L", "ref_low": 0, "ref_high": 14, "critical_high": 52, "panel": "cardiac", "note": "Serial + delta + clinical picture define MI; rises in renal failure/sepsis too."},
    "ck":            {"name": "Creatine kinase (CK)", "units": "U/L", "ref_low": 40, "ref_high": 320, "critical_high": 5000, "panel": "cardiac", "note": "Very high -> rhabdomyolysis (AKI risk)."},
    "bnp":           {"name": "BNP / NT-proBNP", "units": "ng/L", "ref_low": 0, "ref_high": 125, "panel": "cardiac", "note": "Raised -> heart failure (age/renal-dependent cut-offs)."},
    "cholesterol":   {"name": "Total cholesterol", "units": "mmol/L", "ref_low": 0, "ref_high": 5.0, "panel": "lipids"},
    "ldl":           {"name": "LDL cholesterol", "units": "mmol/L", "ref_low": 0, "ref_high": 3.0, "panel": "lipids", "note": "Target lower in high CV risk / established disease."},
    "hdl":           {"name": "HDL cholesterol", "units": "mmol/L", "ref_low": 1.0, "ref_high": 3.0, "panel": "lipids", "note": "Low HDL = risk factor (protective when high)."},
    "triglycerides": {"name": "Triglycerides", "units": "mmol/L", "ref_low": 0, "ref_high": 1.7, "critical_high": 11, "panel": "lipids", "note": "Very high -> pancreatitis risk."},
    "ferritin":      {"name": "Ferritin", "units": "µg/L", "ref_low": 30, "ref_high": 300, "panel": "iron", "note": "Low -> iron deficiency; very high -> inflammation/iron overload/HLH."},
    "iron":          {"name": "Iron (serum)", "units": "µmol/L", "ref_low": 10, "ref_high": 30, "panel": "iron"},
    "transferrin_sat":{"name": "Transferrin saturation", "units": "%", "ref_low": 20, "ref_high": 50, "panel": "iron", "note": "Low -> iron deficiency; >45-50 -> haemochromatosis."},
    "lactate":       {"name": "Lactate", "units": "mmol/L", "ref_low": 0.5, "ref_high": 2.0, "critical_high": 4.0, "note": ">4 -> sepsis/hypoperfusion (part of sepsis-6)."},
    "ammonia":       {"name": "Ammonia", "units": "µmol/L", "ref_low": 11, "ref_high": 35, "critical_high": 100, "note": "High -> hepatic encephalopathy, urea-cycle/valproate."}
  }
}

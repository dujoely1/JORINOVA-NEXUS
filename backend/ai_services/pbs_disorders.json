    "grading_terms": {"1+": "mild", "2+": "moderate", "3+": "marked", "4+": "severe"},
    "source": "Standard haematology morphology references (Bain, Dacie & Lewis; WHO 2022). Curated for JORINOVA NEXUS."
  },

